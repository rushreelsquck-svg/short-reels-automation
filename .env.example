# Copy this file to .env for LOCAL testing only.
# In GitHub Actions, these are set as repo Secrets instead (see README.md) — never commit a real .env file.

# --- Anthropic API (writes the script/title/description/tags) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# --- YouTube Data API v3 OAuth credentials (from Google Cloud Console) ---
YT_CLIENT_ID=673519335469-r4tcg42osk4f4jgq5j5050jp1jiim3gu.apps.googleusercontent.com
YT_CLIENT_SECRET=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
YT_REFRESH_TOKEN=AIzaSyCBn52-Fc1wrxN26hQI9ukOr4720zQvDzM

# --- Optional: Pexels API key for free stock b-roll footage (leave blank to use generated gradient backgrounds instead) ---
PEXELS_API_KEY=

# --- Settings ---
NEWS_REGION=US          # 2-letter region code for Google News
NEWS_LANGUAGE=en        # language code for Google News
YT_CATEGORY_ID=25       # 25 = News & Politics. See README for other category IDs.
YT_PRIVACY_STATUS=public  # public | unlisted | private  (use "unlisted" while you test!)
